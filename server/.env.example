# Persistencia local. Nunca apuntar este archivo a datos reales dentro del repositorio.
DATABASE_PATH=./database/bitforward.sqlite3

# Blockchain experimental. Configurar sólo mediante secretos del entorno.
BLOCKCHAIN_NETWORK=sepolia
BLOCKCHAIN_ENABLED=false
RPC_URL=
CHAIN_ID=11155111
VAULT_CONTRACT_ADDRESS=
STRATEGY_EXECUTOR_ADDRESS=
UNISWAP_ADAPTER_ADDRESS=
AAVE_ADAPTER_ADDRESS=
DEPLOYER_PRIVATE_KEY=
SERVER_PRIVATE_KEY=

# API
PORT=3001
NODE_ENV=development
JWT_SECRET=replace-with-at-least-64-random-characters
COINGECKO_API_KEY=
ETHERSCAN_API_KEY=

# WebSocket y logging
WS_PORT=3002
WS_ENABLED=true
LOG_LEVEL=info
LOG_FILE=logs/bitforward.log
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Controles de riesgo para el laboratorio técnico
MAX_SLIPPAGE=0.01
DEFAULT_GAS_LIMIT=500000
GAS_PRICE_MULTIPLIER=1.1
HEALTH_FACTOR_THRESHOLD=1.2
